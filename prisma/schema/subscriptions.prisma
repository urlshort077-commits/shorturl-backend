model Subscriptions {
    id          String             @id @default(cuid())
    userId      String
    plan        Plan
    paymentId   String             @unique
    purchasedAt DateTime           @default(now())
    expiresAt   DateTime
    status      SubscriptionStatus @default(ACTIVE)

    user    User     @relation(fields: [userId], references: [id], onDelete: Restrict)
    payment Payments @relation(fields: [paymentId], references: [id], onDelete: Restrict)

    @@index([userId])
    @@index([status])
    @@index([expiresAt])
    @@map("subscriptions")
}
